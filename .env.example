# Firebase App Check reCAPTCHA Enterprise score-based site key.
# Required by production Maze Authority callable functions.
NEXT_PUBLIC_FIREBASE_APP_CHECK_SITE_KEY=

# Maze Authority rooms are enabled by default when this variable is unset.
# Set exactly 0 only while draining or explicitly testing legacy rooms.
# NEXT_PUBLIC_MAZE_AUTHORITY_NEW_ROOMS=0

# Local E2E only. Functions skip App Check enforcement in emulator mode.
NEXT_PUBLIC_FIREBASE_EMULATOR=0
NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_PORT=9099
NEXT_PUBLIC_FIREBASE_DATABASE_EMULATOR_PORT=9000
NEXT_PUBLIC_FIREBASE_FUNCTIONS_EMULATOR_PORT=5001
