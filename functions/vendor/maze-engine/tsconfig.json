{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2022",
    "lib": [
      "es2022"
    ],
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true
  },
  "include": [
    "src"
  ]
}
