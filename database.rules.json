{
  "rules": {
    "rooms": {
      ".read": "auth != null",

      "$roomId": {
        ".write": "auth != null && ((!data.exists() && newData.child('createdBy').val() === auth.uid) || (data.exists() && !newData.exists() && (data.child('createdBy').val() === auth.uid || !data.child('lastActivity').exists() || data.child('lastActivity').val() < now - 7200000)))",

        "players": {
          ".write": "auth != null"
        },

        "lastActivity": {
          ".write": "auth != null"
        },

        "status": {
          ".write": "auth != null && root.child('rooms').child($roomId).child('createdBy').val() === auth.uid"
        },
        "deletedBy": {
          ".write": "auth != null && root.child('rooms').child($roomId).child('createdBy').val() === auth.uid"
        },
        "deletedAt": {
          ".write": "auth != null && root.child('rooms').child($roomId).child('createdBy').val() === auth.uid"
        },

        "joinedPlayers": {
          "$uid": {
            ".write": "auth != null && $uid === auth.uid"
          }
        },
        "members": {
          "$uid": {
            ".write": "auth != null && $uid === auth.uid"
          }
        },
        "playerStatus": {
          "$uid": {
            ".write": "auth != null && $uid === auth.uid"
          }
        },
        "spectators": {
          "$uid": {
            ".write": "auth != null && $uid === auth.uid"
          }
        },

        "stats": {
          ".write": "auth != null && root.child('rooms').child($roomId).child('gameState').child('players').child(auth.uid).exists()"
        },

        "gameState": {
          ".write": "auth != null && data.child('players').child(auth.uid).exists()",

          "players": {
            "$playerId": {
              ".write": "auth != null && $playerId === auth.uid"
            }
          }
        }
      }
    },

    "lobbyChat": {
      ".read": "auth != null",
      "$messageId": {
        ".write": "auth != null && !data.exists() && newData.child('userId').val() === auth.uid",
        ".validate": "newData.hasChildren(['userId', 'userName', 'text', 'timestamp']) && newData.child('text').isString() && newData.child('text').val().length > 0 && newData.child('text').val().length <= 500"
      }
    },

    "lobbyOnline": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && $uid === auth.uid"
      }
    },

    "userStatus": {
      "$uid": {
        ".read": "auth != null && $uid === auth.uid",
        ".write": "auth != null && $uid === auth.uid"
      }
    },

    "users": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && $uid === auth.uid"
      }
    },

    "userRooms": {
      "$uid": {
        ".read": "auth != null && $uid === auth.uid",
        ".write": "auth != null && $uid === auth.uid"
      }
    },

    "status": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && $uid === auth.uid"
      }
    }
  }
}
