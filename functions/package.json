{
  "name": "daemok-functions",
  "version": "0.1.0",
  "private": true,
  "main": "lib/index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('lib', { recursive: true, force: true })\"",
    "build:maze-engine": "node ../scripts/generate-maze-engine-vendor.cjs && tsc -p vendor/maze-engine/tsconfig.json",
    "build": "npm run clean && npm run build:maze-engine && tsc",
    "lint": "tsc --noEmit",
    "test": "npm run build && node --test lib/**/*.test.js"
  },
  "dependencies": {
    "firebase-admin": "^13.10.0",
    "firebase-functions": "^7.2.5"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "typescript": "^5.9.0"
  }
}
