{
  "name": "daemok",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test:game-rules": "node scripts/test-game-rules.cjs && node scripts/test-maze-skills.cjs && node scripts/test-game-rule-snapshot.cjs",
    "test:adventure": "node scripts/test-adventure.cjs && node scripts/test-adventure-town.cjs",
    "test:offline-turn": "node scripts/test-offline-turn.cjs",
    "test:database-rules": "npm_config_cache=/tmp/daemok-npm-cache npx firebase-tools emulators:exec --only auth,database --project daemok-155c1 \"node scripts/test-database-rules.cjs\"",
    "test:e2e:adventure": "EMULATOR=1 node scripts/e2e-adventure.cjs",
    "test:e2e:practice": "node scripts/e2e-practice.cjs",
    "test:e2e:multiplayer": "EMULATOR=1 node scripts/e2e-multiplayer.cjs",
    "test:e2e:owner-disconnect": "EMULATOR=1 node scripts/e2e-owner-disconnect.cjs",
    "test:e2e:spectator": "EMULATOR=1 node scripts/e2e-spectator.cjs",
    "sim:wall-budget": "node scripts/sim-wall-balance.cjs",
    "sim:consumables": "node scripts/sim-consumable-caps.cjs",
    "sim:special-walls": "node scripts/sim-special-walls.cjs",
    "sim:wall-combos": "node scripts/sim-wall-combos.cjs"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "firebase": "^11.10.0",
    "lucide-react": "^1.24.0",
    "next": "^15.5.20",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.185.0",
    "eslint": "^9",
    "eslint-config-next": "^15.5.20",
    "playwright": "^1.61.1",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
